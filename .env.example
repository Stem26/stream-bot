# PostgreSQL на сервере 194.87.55.131
# Формат: postgresql://user:password@host:port/database

# Общая БД (или укажи отдельные для каждого сервиса)
DATABASE_URL=postgresql://root:YOUR_PASSWORD@194.87.55.131:5432/stream_bot

# ID администратора для отправки бэкапов БД
# BACKUP_ADMIN_ID=your_telegram_id

# Опционально — отдельные БД для сервисов:
# TELEGRAM_DATABASE_URL=postgresql://root:YOUR_PASSWORD@194.87.55.131:5432/stream_bot
# TWITCH_DATABASE_URL=postgresql://root:YOUR_PASSWORD@194.87.55.131:5432/stream_bot

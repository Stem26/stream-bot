{
  "name": "twitch-service",
  "version": "1.0.0",
  "description": "Twitch бот с интеграцией Telegram",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && npm run build:web",
    "start": "node dist/src/main.js",
    "start:prod": "npm run build && cross-env NODE_ENV=production node dist/src/index.js",
    "dev": "nodemon",
    "dev:all": "concurrently \"npm run dev\" \"wait-on http://127.0.0.1:3000 && npm run dev:web\"",
    "dev:web": "vite --config vite.config.ts",
    "optimize:fon": "node scripts/optimize-fon.js",
    "build:web": "npm run optimize:fon && vite build --config vite.config.ts",
    "build:web:watch": "vite build --config vite.config.ts --watch",
    "nightbot:send": "ts-node src/scripts/nightbot-send.ts",
    "twitch:announcement:test": "ts-node src/scripts/announcement-test.ts",
    "twitch:token:check": "ts-node src/scripts/token-check.ts",
    "stream:notification:test": "ts-node src/scripts/stream-notification-test.ts",
    "eventsub:cleanup": "ts-node src/scripts/cleanup-eventsub.ts",
    "watch": "tsc --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "db:migrate": "ts-node src/database/migrate.ts",
    "db:migrate-data": "ts-node src/database/migrate-data.ts",
    "db:migrate-data:force": "ts-node src/database/migrate-data.ts --force",
    "db:check-counters": "ts-node src/scripts/check-counters.ts",
    "admin:add": "ts-node src/scripts/add-admin.ts",
    "admin:remove": "ts-node src/scripts/remove-admin.ts"
  },
  "keywords": [
    "twitch",
    "bot",
    "typescript",
    "telegram"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@twurple/api": "^8.0.3",
    "@twurple/auth": "^8.0.3",
    "@twurple/chat": "^8.0.3",
    "@twurple/eventsub-ws": "^8.0.3",
    "axios": "^1.6.7",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.3",
    "pino": "^10.3.0",
    "pino-pretty": "^13.1.3",
    "telegraf": "^4.15.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.10.9",
    "@types/ws": "^8.5.13",
    "@vitest/ui": "^4.0.18",
    "concurrently": "^9.2.1",
    "wait-on": "^8.0.1",
    "cross-env": "^10.1.0",
    "nodemon": "^3.0.2",
    "sass": "^1.98.0",
    "sharp": "^0.33.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^8.0.0",
    "vitest": "^4.0.18"
  }
}

{
  "name": "telegram-twitch-bots-monorepo",
  "version": "1.0.0",
  "description": "Монорепозиторий с микросервисами для Telegram и Twitch ботов",
  "private": true,
  "workspaces": [
    "services/telegram-service",
    "services/twitch-service"
  ],
  "scripts": {
    "dev:telegram": "npm --workspace services/telegram-service run dev",
    "dev:twitch": "npm --workspace services/twitch-service run dev",
    "build:telegram": "npm --workspace services/telegram-service run build",
    "build:twitch": "npm --workspace services/twitch-service run build",
    "start:telegram": "npm --workspace services/telegram-service run start",
    "start:twitch": "cross-env NODE_ENV=production npm --workspace services/twitch-service run start",
    "nightbot:send": "npm --workspace services/twitch-service run nightbot:send",
    "twitch:announcement:test": "npm --workspace services/twitch-service run twitch:announcement:test",
    "twitch:token:check": "npm --workspace services/twitch-service run twitch:token:check",
    "stream:notification:test": "npm --workspace services/twitch-service run stream:notification:test",
    "db:migrate:telegram": "npm --workspace services/telegram-service run db:migrate",
    "db:migrate:twitch": "npm --workspace services/twitch-service run db:migrate",
    "db:migrate-data:twitch": "npm --workspace services/twitch-service run db:migrate-data",
    "db:migrate-data:twitch:force": "npm --workspace services/twitch-service run db:migrate-data:force",
    "db:check": "node scripts/db-check.js",
    "db:backup": "node scripts/backup-db.js"
  },
  "keywords": [
    "telegram",
    "twitch",
    "bot",
    "monorepo",
    "microservices"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "cross-env": "^10.1.0",
    "dotenv": "^17.3.1",
    "form-data": "^4.0.1",
    "pg": "^8.18.0",
    "rimraf": "^5.0.5"
  }
}
